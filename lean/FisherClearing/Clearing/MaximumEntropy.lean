import FisherClearing.Clearing.ZeroEquilibrium

/-!
# Maximum-Entropy Price Selection

The positive-temperature price dual is the zero-temperature trader potential
regularized by negative entropy.  This file proves the paper's selection
result: along every sequence of positive temperatures tending to zero, any
sequence of dual-minimizing prices converges to the unique maximum-entropy
zero-temperature price.  A direct corollary applies this to the softmax prices
extracted from primal clearing optima.
-/

namespace FisherClearing

open Topology

variable {ι : Type*} [Fintype ι] [Nonempty ι]
variable {J : Type*} [Fintype J]
variable {K : Type*} [Fintype K] [DecidableEq K]

variable (inst : FullInstance ι J K)

/-- Every cluster point of positive-temperature primal optimizers, as
    temperature tends to zero, is a zero-temperature optimizer. -/
theorem FullInstance.clusterPoint_of_optimal_fills_is_zeroOptimal
    (b : ℕ → ℝ) (hb : ∀ n, 0 < b n) (hb0 : Filter.Tendsto b Filter.atTop (𝓝 0))
    (fill : ℕ → J → ℝ) (hfill : ∀ n, fill n ∈ (boxFeasible : Set (J → ℝ)))
    (hopt : ∀ n,
      IsMaxOn (inst.objective (b n)) boxFeasible (fill n))
    {zeroFill : J → ℝ}
    (hcluster : MapClusterPt zeroFill Filter.atTop fill) :
    zeroFill ∈ (boxFeasible : Set (J → ℝ)) ∧
      IsMaxOn inst.objectiveZero boxFeasible zeroFill := by
  rcases hcluster.tendsto_subseq with
    ⟨subseq, hsubseqMono, hsubseq⟩
  have hsubseqTop :
      Filter.Tendsto subseq Filter.atTop Filter.atTop :=
    hsubseqMono.tendsto_atTop
  have hbsub :
      Filter.Tendsto (b ∘ subseq) Filter.atTop (𝓝 0) :=
    hb0.comp hsubseqTop
  have hzeroFill :
      zeroFill ∈ (boxFeasible : Set (J → ℝ)) :=
    isCompact_boxFeasible.isClosed.mem_of_tendsto hsubseq
      (Filter.Eventually.of_forall fun n => hfill (subseq n))
  refine ⟨hzeroFill, ?_⟩
  intro other hother
  have hpenalty :
      Filter.Tendsto
        (fun n =>
          b (subseq n) * Real.log (Fintype.card ι))
        Filter.atTop (𝓝 0) := by
    simpa only [Function.comp_apply, zero_mul] using
      hbsub.mul_const (Real.log (Fintype.card ι))
  have hleft :
      Filter.Tendsto
        (fun n =>
          inst.objectiveZero other -
            b (subseq n) * Real.log (Fintype.card ι))
        Filter.atTop (𝓝 (inst.objectiveZero other)) := by
    simpa only [sub_zero] using
      hpenalty.const_sub (inst.objectiveZero other)
  have hright :
      Filter.Tendsto
        (fun n => inst.objectiveZero (fill (subseq n)))
        Filter.atTop (𝓝 (inst.objectiveZero zeroFill)) := by
    simpa only [Function.comp_def] using
      inst.continuous_objectiveZero.tendsto zeroFill |>.comp hsubseq
  apply le_of_tendsto_of_tendsto hleft hright
  exact Filter.Eventually.of_forall fun n => by
    have hlower :=
      (inst.objective_sandwich_zero
        (hb (subseq n)) other).1
    have hbest := hopt (subseq n) hother
    have hupper :=
      (inst.objective_sandwich_zero
        (hb (subseq n)) (fill (subseq n))).2
    exact hlower.trans (hbest.trans hupper)

omit [Fintype K] [DecidableEq K] in
/-- Along any sequence of temperatures tending to infinity, softmax prices
    generated by feasible fills converge to the uniform price.  Feasibility
    makes every net-demand coordinate uniformly bounded, so the statement also
    applies when the fills vary with temperature. -/
theorem FullInstance.tendsto_softmax_prices_to_uniform (b : ℕ → ℝ)
    (hbTop : Filter.Tendsto b Filter.atTop Filter.atTop) (fill : ℕ → J → ℝ)
    (hfill : ∀ n, fill n ∈ (boxFeasible : Set (J → ℝ))) :
    Filter.Tendsto
      (fun n => softmax (b n) (inst.netDemand (fill n)))
      Filter.atTop
      (𝓝 (fun _ : ι => 1 / (Fintype.card ι : ℝ))) := by
  have hbound : ∀ s : ι, ∀ n,
      |inst.netDemand (fill n) s| ≤
        ∑ j : J, |inst.payoff j s| := by
    intro s n
    unfold FullInstance.netDemand
    calc
      |∑ j : J, fill n j * inst.payoff j s| ≤
          ∑ j : J, |fill n j * inst.payoff j s| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ j : J, |inst.payoff j s| := by
        apply Finset.sum_le_sum
        intro j _
        have hj := Set.mem_pi.mp (hfill n) j trivial
        rw [abs_mul, abs_of_nonneg hj.1]
        exact mul_le_of_le_one_left (abs_nonneg _) hj.2
  have hscaled : ∀ s : ι,
      Filter.Tendsto
        (fun n => inst.netDemand (fill n) s / b n)
        Filter.atTop (𝓝 0) := by
    intro s
    let C := ∑ j : J, |inst.payoff j s|
    apply tendsto_bdd_div_atTop_nhds_zero
      (b := -C) (B := C)
    · exact Filter.Eventually.of_forall fun n =>
        (abs_le.mp (hbound s n)).1
    · exact Filter.Eventually.of_forall fun n =>
        (abs_le.mp (hbound s n)).2
    · exact hbTop
  have hexp : ∀ s : ι,
      Filter.Tendsto
        (fun n =>
          Real.exp (inst.netDemand (fill n) s / b n))
        Filter.atTop (𝓝 1) := by
    intro s
    have h :=
      (Real.continuous_exp.tendsto 0).comp (hscaled s)
    rw [Real.exp_zero] at h
    simpa only [Function.comp_def] using h
  have hsum :
      Filter.Tendsto
        (fun n => sumExp (b n) (inst.netDemand (fill n)))
        Filter.atTop (𝓝 (Fintype.card ι : ℝ)) := by
    simpa only [sumExp, Finset.sum_const, Finset.card_univ,
      nsmul_eq_mul, mul_one] using
      tendsto_finsetSum Finset.univ (fun s _ => hexp s)
  rw [tendsto_pi_nhds]
  intro s
  have hcard :
      (Fintype.card ι : ℝ) ≠ 0 := by
    exact_mod_cast Fintype.card_ne_zero
  unfold softmax
  exact ((hexp s).div hsum hcard).congr'
    (Filter.Eventually.of_forall fun _ => rfl)

omit [Nonempty ι] in
/-- A positive-temperature dual minimizer has at least as much Shannon entropy
    as every zero-temperature dual minimizer. -/
theorem FullInstance.zeroPrice_entropy_le_regularized_minimizer
    {b : ℝ} (hb : 0 < b) {price zeroPrice : ι → ℝ}
    (hprice : price ∈ stdSimplex ℝ ι) (hzero : zeroPrice ∈ inst.zeroPriceSet)
    (hmin : ∀ other ∈ stdSimplex ℝ ι,
      inst.priceDualObjective b price ≤
        inst.priceDualObjective b other) :
    shannonEntropy zeroPrice ≤ shannonEntropy price := by
  have hpotential :=
    hzero.2 price hprice
  have hregularized := hmin zeroPrice hzero.1
  unfold FullInstance.priceDualObjective at hregularized
  have hscaled :
      b * negEntropy price ≤ b * negEntropy zeroPrice := by
    linarith
  have hneg :
      negEntropy price ≤ negEntropy zeroPrice :=
    le_of_mul_le_mul_left hscaled hb
  simpa only [shannonEntropy] using neg_le_neg hneg

omit [Nonempty ι] in
/-- The excess zero-temperature potential of a regularized minimizer is
    nonnegative and at most `b * |ι|`. -/
theorem FullInstance.regularized_minimizer_potential_gap
    {b : ℝ} (hb : 0 < b) {price zeroPrice : ι → ℝ}
    (hprice : price ∈ stdSimplex ℝ ι) (hzero : zeroPrice ∈ inst.zeroPriceSet)
    (hmin : ∀ other ∈ stdSimplex ℝ ι,
      inst.priceDualObjective b price ≤
        inst.priceDualObjective b other) :
    0 ≤ inst.pricePotential price - inst.pricePotential zeroPrice ∧
      inst.pricePotential price - inst.pricePotential zeroPrice ≤
        b * (Fintype.card ι : ℝ) := by
  have hpotential :=
    hzero.2 price hprice
  have hregularized := hmin zeroPrice hzero.1
  have hentropyUpper :=
    shannonEntropy_le_card_on_simplex hprice
  have hentropyLower :=
    shannonEntropy_nonneg_on_simplex hzero.1
  have hentropyDiff :
      shannonEntropy price - shannonEntropy zeroPrice ≤
        (Fintype.card ι : ℝ) := by
    linarith
  have hscaled :
      b * (shannonEntropy price - shannonEntropy zeroPrice) ≤
        b * (Fintype.card ι : ℝ) :=
    mul_le_mul_of_nonneg_left hentropyDiff hb.le
  unfold FullInstance.priceDualObjective at hregularized
  have hgap :
      inst.pricePotential price - inst.pricePotential zeroPrice ≤
        b * (shannonEntropy price - shannonEntropy zeroPrice) := by
    simp only [shannonEntropy] at *
    linarith
  exact ⟨by linarith, hgap.trans hscaled⟩

/-- Negative-entropy regularization selects the unique maximum-entropy
    minimizer of the zero-temperature price potential. -/
theorem FullInstance.tendsto_regularized_prices_to_maxEntropy
    (b : ℕ → ℝ) (hb : ∀ n, 0 < b n) (hb0 : Filter.Tendsto b Filter.atTop (𝓝 0))
    (price : ℕ → ι → ℝ) (hprice : ∀ n, price n ∈ stdSimplex ℝ ι)
    (hmin : ∀ n, ∀ other ∈ stdSimplex ℝ ι,
      inst.priceDualObjective (b n) (price n) ≤
        inst.priceDualObjective (b n) other) :
    ∃ priceZero : ι → ℝ,
      priceZero ∈ inst.zeroPriceSet ∧
      IsMaxOn shannonEntropy inst.zeroPriceSet priceZero ∧
      Filter.Tendsto price Filter.atTop (𝓝 priceZero) := by
  rcases inst.existsUnique_maxEntropy_zeroPrice with
    ⟨priceZero, hzero, hunique⟩
  refine ⟨priceZero, hzero.1, hzero.2, ?_⟩
  apply (isCompact_stdSimplex ℝ ι).tendsto_nhds_of_unique_mapClusterPt
    (Filter.Eventually.of_forall hprice)
  intro cluster hclusterSimplex hcluster
  rcases hcluster.tendsto_subseq with
    ⟨subseq, hsubseqMono, hsubseq⟩
  have hsubseqTop :
      Filter.Tendsto subseq Filter.atTop Filter.atTop :=
    hsubseqMono.tendsto_atTop
  have hbsub :
      Filter.Tendsto (b ∘ subseq) Filter.atTop (𝓝 0) :=
    hb0.comp hsubseqTop
  have hupper :
      Filter.Tendsto
        (fun n => b (subseq n) * (Fintype.card ι : ℝ))
        Filter.atTop (𝓝 0) := by
    simpa only [Function.comp_apply, zero_mul] using
      hbsub.mul_const (Fintype.card ι : ℝ)
  have hgapZero :
      Filter.Tendsto
        (fun n =>
          inst.pricePotential (price (subseq n)) -
            inst.pricePotential priceZero)
        Filter.atTop (𝓝 0) := by
    apply squeeze_zero
    · intro n
      exact (inst.regularized_minimizer_potential_gap
        (hb (subseq n)) (hprice (subseq n)) hzero.1
        (hmin (subseq n))).1
    · intro n
      exact (inst.regularized_minimizer_potential_gap
        (hb (subseq n)) (hprice (subseq n)) hzero.1
        (hmin (subseq n))).2
    · exact hupper
  have hpotentialSub :
      Filter.Tendsto
        (fun n => inst.pricePotential (price (subseq n)))
        Filter.atTop (𝓝 (inst.pricePotential cluster)) := by
    simpa only [Function.comp_def] using
      (inst.continuous_pricePotential.tendsto cluster).comp hsubseq
  have hgapAtCluster :
      Filter.Tendsto
        (fun n =>
          inst.pricePotential (price (subseq n)) -
            inst.pricePotential priceZero)
        Filter.atTop
        (𝓝 (inst.pricePotential cluster -
          inst.pricePotential priceZero)) :=
    hpotentialSub.sub_const _
  have hpotentialEq :
      inst.pricePotential cluster =
        inst.pricePotential priceZero := by
    have hzeroGap :
        inst.pricePotential cluster -
            inst.pricePotential priceZero = 0 :=
      tendsto_nhds_unique hgapAtCluster hgapZero
    linarith
  have hclusterZero : cluster ∈ inst.zeroPriceSet := by
    refine ⟨hclusterSimplex, ?_⟩
    intro other hother
    rw [hpotentialEq]
    exact hzero.1.2 other hother
  have hentropySub :
      Filter.Tendsto
        (fun n => shannonEntropy (price (subseq n)))
        Filter.atTop (𝓝 (shannonEntropy cluster)) := by
    simpa only [Function.comp_def] using
      (continuous_shannonEntropy.tendsto cluster).comp hsubseq
  have hentropyLower :
      shannonEntropy priceZero ≤ shannonEntropy cluster := by
    apply ge_of_tendsto' hentropySub
    intro n
    exact inst.zeroPrice_entropy_le_regularized_minimizer
      (hb (subseq n)) (hprice (subseq n)) hzero.1
      (hmin (subseq n))
  have hentropyEq :
      shannonEntropy priceZero = shannonEntropy cluster :=
    le_antisymm hentropyLower (hzero.2 hclusterZero)
  apply hunique cluster
  refine ⟨hclusterZero, ?_⟩
  intro other hother
  rw [← hentropyEq]
  exact hzero.2 hother

/-- **Maximum-entropy selection for clearing prices.**  Softmax prices
    extracted from any sequence of positive-temperature primal optima converge
    to the same maximum-entropy zero-temperature price. -/
theorem FullInstance.tendsto_softmax_prices_to_maxEntropy (b : ℕ → ℝ) (hb : ∀ n, 0 < b n)
    (hb0 : Filter.Tendsto b Filter.atTop (𝓝 0)) (fill : ℕ → J → ℝ)
    (hfill : ∀ n, fill n ∈ (boxFeasible : Set (J → ℝ))) (hopt : ∀ n,
      IsMaxOn (inst.objective (b n)) boxFeasible (fill n)) :
    ∃ priceZero : ι → ℝ,
      priceZero ∈ inst.zeroPriceSet ∧
      IsMaxOn shannonEntropy inst.zeroPriceSet priceZero ∧
      Filter.Tendsto
        (fun n => softmax (b n) (inst.netDemand (fill n)))
        Filter.atTop (𝓝 priceZero) := by
  apply inst.tendsto_regularized_prices_to_maxEntropy b hb hb0
  · intro n
    exact softmax_mem_stdSimplex (b n) (inst.netDemand (fill n))
  · intro n
    exact (inst.softmax_minimizes_priceDual
      (hb n) (fill n) (hfill n) (hopt n)).2

/-- **Zero-temperature strong duality and equilibrium existence.**  Every
    zero-temperature primal optimum is supported by the unique
    maximum-entropy zero price. -/
theorem FullInstance.exists_maxEntropy_zeroEquilibrium_of_optimal (zeroFill : J → ℝ)
    (hzeroFill : zeroFill ∈ (boxFeasible : Set (J → ℝ)))
    (hzeroOpt : IsMaxOn inst.objectiveZero boxFeasible zeroFill) :
    ∃ priceZero : ι → ℝ,
      priceZero ∈ inst.zeroPriceSet ∧
      IsMaxOn shannonEntropy inst.zeroPriceSet priceZero ∧
      inst.pricePotential priceZero = inst.objectiveZero zeroFill ∧
      inst.ZeroCompetitiveEquilibrium zeroFill priceZero := by
  classical
  let b : ℕ → ℝ := fun n => 1 / ((n : ℝ) + 1)
  have hb : ∀ n, 0 < b n := by
    intro n
    exact Nat.one_div_pos_of_nat
  have hb0 :
      Filter.Tendsto b Filter.atTop (𝓝 0) := by
    exact tendsto_one_div_add_atTop_nhds_zero_nat
  let positiveFill : ℕ → J → ℝ := fun n =>
    Classical.choose (inst.exists_optimal_fill (b n))
  have hpositiveFill :
      ∀ n, positiveFill n ∈ (boxFeasible : Set (J → ℝ)) := by
    intro n
    exact (Classical.choose_spec
      (inst.exists_optimal_fill (b n))).1
  have hpositiveOpt :
      ∀ n, IsMaxOn (inst.objective (b n)) boxFeasible
        (positiveFill n) := by
    intro n
    exact (Classical.choose_spec
      (inst.exists_optimal_fill (b n))).2
  rcases inst.tendsto_softmax_prices_to_maxEntropy
      b hb hb0 positiveFill hpositiveFill hpositiveOpt with
    ⟨priceZero, hpriceZero, hmaxEntropy, hpriceTendsto⟩
  let price : ℕ → ι → ℝ := fun n =>
    softmax (b n) (inst.netDemand (positiveFill n))
  have hpriceSimplex :
      ∀ n, price n ∈ stdSimplex ℝ ι := by
    intro n
    exact softmax_mem_stdSimplex
      (b n) (inst.netDemand (positiveFill n))
  have hpriceTendsto' :
      Filter.Tendsto price Filter.atTop (𝓝 priceZero) := by
    exact hpriceTendsto
  have hpotentialTendsto :
      Filter.Tendsto
        (fun n => inst.pricePotential (price n))
        Filter.atTop (𝓝 (inst.pricePotential priceZero)) := by
    simpa only [Function.comp_def] using
      (inst.continuous_pricePotential.tendsto priceZero).comp
        hpriceTendsto'
  have hentropyProduct :
      Filter.Tendsto
        (fun n => b n * shannonEntropy (price n))
        Filter.atTop (𝓝 0) := by
    have hupper :
        Filter.Tendsto
          (fun n => b n * (Fintype.card ι : ℝ))
          Filter.atTop (𝓝 0) := by
      simpa only [zero_mul] using
        hb0.mul_const (Fintype.card ι : ℝ)
    apply squeeze_zero
    · intro n
      exact mul_nonneg (hb n).le
        (shannonEntropy_nonneg_on_simplex (hpriceSimplex n))
    · intro n
      exact mul_le_mul_of_nonneg_left
        (shannonEntropy_le_card_on_simplex (hpriceSimplex n))
        (hb n).le
    · exact hupper
  have hregularizerTendsto :
      Filter.Tendsto
        (fun n => b n * negEntropy (price n))
        Filter.atTop (𝓝 0) := by
    simpa only [shannonEntropy, mul_neg, neg_neg, neg_zero] using
      hentropyProduct.neg
  have hdualTendsto :
      Filter.Tendsto
        (fun n => inst.priceDualObjective (b n) (price n))
        Filter.atTop (𝓝 (inst.pricePotential priceZero)) := by
    simpa only [FullInstance.priceDualObjective, add_zero] using
      hpotentialTendsto.add hregularizerTendsto
  have hduality :
      ∀ n, inst.priceDualObjective (b n) (price n) =
        inst.objective (b n) (positiveFill n) := by
    intro n
    exact (inst.softmax_minimizes_priceDual
      (hb n) (positiveFill n) (hpositiveFill n)
      (hpositiveOpt n)).1
  have hlogCard :
      0 ≤ Real.log (Fintype.card ι : ℝ) := by
    apply Real.log_nonneg
    exact_mod_cast Fintype.card_pos (α := ι)
  have hvalueGapTendsto :
      Filter.Tendsto
        (fun n =>
          inst.objectiveZero zeroFill -
            inst.objective (b n) (positiveFill n))
        Filter.atTop (𝓝 0) := by
    have hupper :
        Filter.Tendsto
          (fun n => b n * Real.log (Fintype.card ι : ℝ))
          Filter.atTop (𝓝 0) := by
      simpa only [zero_mul] using
        hb0.mul_const (Real.log (Fintype.card ι : ℝ))
    apply squeeze_zero
      (g := fun n => b n * Real.log (Fintype.card ι : ℝ))
    · intro n
      have hpositiveZero :=
        (inst.objective_sandwich_zero
          (hb n) (positiveFill n)).2
      have hzeroBest := hzeroOpt (hpositiveFill n)
      change inst.objectiveZero (positiveFill n) ≤
        inst.objectiveZero zeroFill at hzeroBest
      linarith
    · intro n
      have hpositiveBest :=
        hpositiveOpt n hzeroFill
      change inst.objective (b n) zeroFill ≤
        inst.objective (b n) (positiveFill n) at hpositiveBest
      have hfixedLower :=
        (inst.objective_sandwich_zero (hb n) zeroFill).1
      linarith
    · exact hupper
  have hprimalValueTendsto :
      Filter.Tendsto
        (fun n => inst.objective (b n) (positiveFill n))
        Filter.atTop (𝓝 (inst.objectiveZero zeroFill)) := by
    have h := hvalueGapTendsto.const_sub
      (inst.objectiveZero zeroFill)
    simpa only [sub_sub_cancel, sub_zero] using h
  have hprimalValueTendsto' :
      Filter.Tendsto
        (fun n => inst.objective (b n) (positiveFill n))
        Filter.atTop (𝓝 (inst.pricePotential priceZero)) := by
    apply hdualTendsto.congr'
    exact Filter.Eventually.of_forall hduality
  have hequality :
      inst.pricePotential priceZero =
        inst.objectiveZero zeroFill :=
    tendsto_nhds_unique hprimalValueTendsto'
      hprimalValueTendsto
  have hequilibrium :
      inst.ZeroCompetitiveEquilibrium zeroFill priceZero :=
    inst.zeroCompetitiveEquilibrium_of_primalDualEquality
      zeroFill hzeroFill priceZero hpriceZero.1 hequality
  exact ⟨priceZero, hpriceZero, hmaxEntropy, hequality,
    hequilibrium⟩

/-- The same supporting maximum-entropy price yields the paper's
    agent-by-agent zero-temperature equilibrium. -/
theorem FullInstance.exists_maxEntropy_zeroAgentEquilibrium_of_optimal (zeroFill : J → ℝ)
    (hzeroFill : zeroFill ∈ (boxFeasible : Set (J → ℝ)))
    (hzeroOpt : IsMaxOn inst.objectiveZero boxFeasible zeroFill) :
    ∃ priceZero : ι → ℝ,
      priceZero ∈ inst.zeroPriceSet ∧
      IsMaxOn shannonEntropy inst.zeroPriceSet priceZero ∧
      inst.pricePotential priceZero = inst.objectiveZero zeroFill ∧
      inst.ZeroAgentCompetitiveEquilibrium zeroFill priceZero := by
  rcases inst.exists_maxEntropy_zeroEquilibrium_of_optimal
      zeroFill hzeroFill hzeroOpt with
    ⟨priceZero, hprice, hentropy, hduality, heq⟩
  exact ⟨priceZero, hprice, hentropy, hduality, heq.toAgent inst⟩

/-- Exact zero-temperature equivalence between clearing optimality and
    agent-by-agent competitive equilibrium. -/
theorem FullInstance.isZeroOptimal_iff_exists_agentCompetitiveEquilibrium (zeroFill : J → ℝ)
    (hzeroFill : zeroFill ∈ (boxFeasible : Set (J → ℝ))) :
    IsMaxOn inst.objectiveZero boxFeasible zeroFill ↔
      ∃ price : ι → ℝ,
        inst.ZeroAgentCompetitiveEquilibrium zeroFill price := by
  constructor
  · intro hopt
    rcases inst.exists_maxEntropy_zeroAgentEquilibrium_of_optimal
        zeroFill hzeroFill hopt with
      ⟨price, _, _, _, heq⟩
    exact ⟨price, heq⟩
  · rintro ⟨price, heq⟩
    exact heq.isOptimal inst

/-- The zero-temperature clearing program admits a competitive equilibrium,
    and its price is the maximum-entropy zero price. -/
theorem FullInstance.exists_maxEntropy_zeroEquilibrium :
    ∃ fill : J → ℝ, ∃ price : ι → ℝ,
      inst.ZeroCompetitiveEquilibrium fill price ∧
      price ∈ inst.zeroPriceSet ∧
      IsMaxOn shannonEntropy inst.zeroPriceSet price := by
  rcases inst.exists_optimal_fill_zero with
    ⟨fill, hfill, hopt⟩
  rcases inst.exists_maxEntropy_zeroEquilibrium_of_optimal
      fill hfill hopt with
    ⟨price, hprice, hmax, _heq, hequilibrium⟩
  exact ⟨fill, price, hequilibrium, hprice, hmax⟩

end FisherClearing
